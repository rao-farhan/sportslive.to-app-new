# Secrets & Build Configurations
# Copy this file to 'local.properties' and fill in your actual values.
# DO NOT commit 'local.properties' to version control.

# Base URL for API calls
BASE_URL=https://api.exmaple.com

# Your private API Key
API_KEY=your_actual_secret_api_key_here

# XOR Key used for basic obfuscation (Integer)
XOR_KEY=42

# Application Metadata
# Internal project/product name used by Gradle and iOS binary naming
PROJECT_NAME=ExampleApp
# User-facing app name
APP_NAME=Example App
# Optional per-platform titles (fallback to APP_NAME when omitted)
WEB_APP_TITLE=Example App (Web)
DESKTOP_APP_TITLE=Example App (Desktop)
# Package/bundle identifier for Android, iOS, and desktop distributions
APP_ID=com.example.app
APP_VERSION_NAME=1.0.0
APP_VERSION_CODE=1

# iOS Specific
TEAM_ID=XXXXXXXXXX
